generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["ea_gateway"]
}

// ─── EA Gateway ───────────────────────────────────────────────────────────────

model AuditEvent {
  id          String   @id @default(cuid())
  terminalId  String
  type        String
  sequenceNum Int?
  sentAt      DateTime?
  payload     Json
  createdAt   DateTime @default(now())

  @@schema("ea_gateway")
}
